<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ 백업/전송 정책. device_token·invite_code 등 민감값이 클라우드 백업
  또는 기기간 복사(D2D)로 평문 추출되는 경로를 차단한다.
  계정 복원은 SSAID(Android)/Keychain(iOS) 기반 device_id로 재등록되므로
  앱 데이터 백업 자체가 불필요하다.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
